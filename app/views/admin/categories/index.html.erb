<h1>Manage Categories</h1>
<p><%= link_to "New Category", new_admin_category_path %></p>

<table>
  <thead>
    <tr>
      <th>Name</th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    <% @categories.each do |category| %>
      <tr>
        <td><%= category.name %></td>
        <td>
          <%= link_to "Show", admin_category_path(category) %>
          <%= link_to "Edit", edit_admin_category_path(category) %>
          <%= link_to "Delete", admin_category_path(category), data: { turbo_method: :delete, turbo_confirm: "Delete this category?" } %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

