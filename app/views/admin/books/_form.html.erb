<% if @book.errors.any? %>
  <div class="errors">
    <h2><%= pluralize(@book.errors.count, "error") %> prevented this book from being saved:</h2>
    <ul>
      <% @book.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<%= form_with model: [:admin, @book], local: true do |form| %>
  <div>
    <%= form.label :title %>
    <%= form.text_field :title, required: true %>
  </div>

  <div>
    <%= form.label :author %>
    <%= form.text_field :author, required: true %>
  </div>

  <div>
    <%= form.label :isbn %>
    <%= form.text_field :isbn, required: true %>
  </div>

  <div>
    <%= form.label :category_id, "Category" %>
    <%= form.collection_select :category_id, Category.order(:name), :id, :name, prompt: "Select category" %>
  </div>

  <div>
    <%= form.label :description, "Book Summary" %>
    <%= form.text_area :description, rows: 4 %>
  </div>

  <div>
    <%= form.label :total_copies %>
    <%= form.number_field :total_copies, min: 0 %>
  </div>

  <div>
    <%= form.label :available_copies %>
    <%= form.number_field :available_copies, min: 0 %>
  </div>

  <%= form.submit %>
<% end %>

