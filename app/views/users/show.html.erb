<h1>My Profile</h1>

<p><strong>Email:</strong> <%= @user.email %></p>
<p><strong>Role:</strong> <%= @user.role %></p>
<p><strong>Status:</strong> <%= @user.status %></p>

<% if @user.user_profile %>
  <p><strong>Full name:</strong> <%= @user.user_profile.full_name %></p>
  <p><strong>Phone:</strong> <%= @user.user_profile.phone.presence || "-" %></p>
  <p><strong>Address:</strong> <%= @user.user_profile.address.presence || "-" %></p>
<% end %>

<p><%= link_to "Edit Profile", edit_user_path(@user) %></p>

